GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# NextAuth — generate secret: openssl rand -base64 32
NEXTAUTH_SECRET=

# Local development
NEXTAUTH_URL=http://localhost:3000

